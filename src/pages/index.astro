---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Silvia Corpas | Peluquería y Estética Avanzada"
  description="Peluquería y estética avanzada. Especialistas en coloración, corte, tratamientos capilares y belleza premium. Pide tu cita por WhatsApp."
>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black:   #0a0a0a;
    --white:   #f8f5f0;
    --gold:    #c9a96e;
    --gold-lt: #e8d5b0;
    --gray:    #8a8a8a;
    --dark:    #141414;
    --border:  rgba(201,169,110,0.15);
    --font-serif: 'Cormorant Garamond', Georgia, serif;
    --font-sans:  'Montserrat', sans-serif;
    --ease: cubic-bezier(0.4, 0, 0.2, 1);
  }

  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--font-sans);
    font-weight: 300;
    line-height: 1.7;
    overflow-x: hidden;
  }

  ::selection { background: var(--gold); color: var(--black); }
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--black); }
  ::-webkit-scrollbar-thumb { background: var(--gold); }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>

<!-- ══════════ NAVBAR ══════════ -->
<style>
  #navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.4rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.4s var(--ease), padding 0.4s var(--ease),
                border-color 0.4s var(--ease);
    border-bottom: 1px solid transparent;
  }
  #navbar.scrolled {
    background: rgba(10,10,10,0.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 1rem 3rem;
    border-bottom-color: var(--border);
  }
  .nav-logo {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--white);
    flex-shrink: 0;
  }
  .nav-logo span { color: var(--gold); }
  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    align-items: center;
  }
  .nav-links a {
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(248,245,240,0.6);
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta {
    padding: 0.55rem 1.6rem !important;
    border: 1px solid var(--gold) !important;
    color: var(--gold) !important;
    transition: background 0.3s, color 0.3s !important;
  }
  .nav-cta:hover {
    background: var(--gold) !important;
    color: var(--black) !important;
  }
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }
  .nav-hamburger span {
    display: block;
    width: 24px; height: 1px;
    background: var(--white);
  }
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-hamburger { display: flex; }
    #navbar { padding: 1.2rem 1.5rem; }
  }
</style>

<header>
  <nav id="navbar" aria-label="Navegación principal">
    <div class="nav-logo">Silvia <span>Corpas</span></div>
    <ul class="nav-links">
      <li><a href="#servicios">Servicios</a></li>
      <li><a href="#nosotras">Nosotras</a></li>
      <li><a href="#galeria">Galería</a></li>
      <li><a href="#contacto" class="nav-cta">Reservar cita</a></li>
    </ul>
    <button class="nav-hamburger" aria-label="Menú" id="hamburger">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<!-- ══════════ HERO ══════════ -->
<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 1.5rem 4rem;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 55% at 50% 25%, rgba(201,169,110,0.08) 0%, transparent 65%),
      radial-gradient(ellipse 50% 70% at 80% 75%, rgba(201,169,110,0.04) 0%, transparent 55%),
      var(--black);
    z-index: 0;
  }
  .hero-vline {
    position: absolute;
    top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent 0%, rgba(201,169,110,0.25) 40%, transparent 100%);
    z-index: 0;
  }
  .hero-vline:nth-child(1) { left: 12%; }
  .hero-vline:nth-child(2) { right: 12%; }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.6rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 2.2rem;
    animation: fadeUp 0.9s var(--ease) 0.2s both;
  }
  .hero-badge::before, .hero-badge::after {
    content: '';
    width: 36px; height: 1px;
    background: var(--gold);
    opacity: 0.55;
  }
  .hero-logo-wrap {
    width: 88px; height: 88px;
    border-radius: 50%;
    border: 1px solid rgba(201,169,110,0.35);
    margin: 0 auto 2.2rem;
    padding: 4px;
    overflow: hidden;
    animation: fadeUp 0.9s var(--ease) 0.4s both;
  }
  .hero-logo-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8.5vw, 6.8rem);
    font-weight: 300;
    line-height: 1.06;
    letter-spacing: 0.02em;
    margin-bottom: 1.6rem;
    animation: fadeUp 0.9s var(--ease) 0.6s both;
  }
  .hero-title em { font-style: italic; color: var(--gold); }
  .hero-sub {
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 3.2rem;
    animation: fadeUp 0.9s var(--ease) 0.8s both;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeUp 0.9s var(--ease) 1s both;
  }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.95rem 2.2rem;
    background: var(--gold);
    color: var(--black);
    font-size: 0.62rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase;
    transition: background 0.3s, transform 0.25s;
  }
  .btn-primary:hover { background: var(--gold-lt); transform: translateY(-2px); }
  .btn-outline {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.95rem 2.2rem;
    border: 1px solid rgba(248,245,240,0.22);
    color: var(--white);
    font-size: 0.62rem; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase;
    transition: border-color 0.3s, color 0.3s, transform 0.25s;
  }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }
  .hero-scroll {
    position: absolute;
    bottom: 2.2rem; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    animation: fadeIn 1s var(--ease) 1.4s both;
  }
  .hero-scroll span {
    font-size: 0.5rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gray);
  }
  .scroll-bar {
    width: 1px; height: 46px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollDrop 2.2s ease-in-out infinite;
  }
  @keyframes scrollDrop {
    0%   { transform: scaleY(0); transform-origin: top; opacity: 1; }
    60%  { transform: scaleY(1); transform-origin: top; opacity: 1; }
    100% { transform: scaleY(1); opacity: 0; }
  }
</style>

<section class="hero" id="inicio" aria-label="Silvia Corpas Peluquería y Estética">
  <div class="hero-bg">
    <div class="hero-vline"></div>
    <div class="hero-vline"></div>
  </div>
  <div class="hero-inner">
    <p class="hero-badge">Peluquería &amp; Estética Avanzada</p>
    <div class="hero-logo-wrap">
      <img src="/logo.jpg" alt="Logo Silvia Corpas" width="88" height="88" />
    </div>
    <h1 class="hero-title">El arte de<br/><em>transformar</em> tu imagen</h1>
    <p class="hero-sub">Coloración &nbsp;·&nbsp; Corte &nbsp;·&nbsp; Tratamientos &nbsp;·&nbsp; Estética</p>
    <div class="hero-actions">
      <a href="https://wa.me/34000000000?text=Hola%20Silvia%2C%20me%20gustar%C3%ADa%20pedir%20cita" class="btn-primary" target="_blank" rel="noopener noreferrer">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Reservar cita
      </a>
      <a href="#servicios" class="btn-outline">
        Ver servicios
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-bar"></div>
  </div>
</section>

<!-- ══════════ STATS ══════════ -->
<style>
  .stats-strip {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 2.8rem 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    text-align: center;
    gap: 1rem;
  }
  .stat { border-right: 1px solid rgba(255,255,255,0.05); }
  .stat:last-child { border-right: none; }
  .stat-num {
    font-family: var(--font-serif);
    font-size: 2.6rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gray);
    margin-top: 0.4rem;
  }
  @media (max-width: 640px) {
    .stats-strip { grid-template-columns: repeat(2,1fr); padding: 2rem 1.5rem; }
    .stat:nth-child(2) { border-right: none; }
  }
</style>

<section class="stats-strip" aria-label="Datos de Silvia Corpas">
  <div class="stat"><p class="stat-num">+10</p><p class="stat-label">Años experiencia</p></div>
  <div class="stat"><p class="stat-num">+800</p><p class="stat-label">Clientas felices</p></div>
  <div class="stat"><p class="stat-num">100%</p><p class="stat-label">Productos premium</p></div>
  <div class="stat"><p class="stat-num">⭐5.0</p><p class="stat-label">Valoración media</p></div>
</section>

<!-- ══════════ SERVICIOS ══════════ -->
<style>
  .section-wrap { padding: 6rem 3rem; max-width: 1200px; margin: 0 auto; }
  .section-tag {
    display: inline-flex; align-items: center; gap: 0.8rem;
    font-size: 0.58rem; letter-spacing: 0.32em; text-transform: uppercase; color: var(--gold);
    margin-bottom: 1.4rem;
  }
  .section-tag::before { content: ''; width: 28px; height: 1px; background: var(--gold); }
  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4.5vw, 3.8rem);
    font-weight: 300;
    line-height: 1.15;
    margin-bottom: 0.8rem;
  }
  .section-title em { font-style: italic; color: var(--gold); }
  .section-lead {
    font-size: 0.82rem;
    color: var(--gray);
    max-width: 480px;
    line-height: 1.85;
    margin-bottom: 3.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--border);
    gap: 1px;
    background: var(--border);
  }
  .svc-card {
    background: var(--black);
    padding: 2.2rem 1.8rem;
    position: relative;
    overflow: hidden;
    transition: background 0.35s var(--ease);
  }
  .svc-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s var(--ease);
  }
  .svc-card:hover { background: #111; }
  .svc-card:hover::after { transform: scaleX(1); }
  .svc-icon {
    width: 42px; height: 42px;
    border: 1px solid rgba(201,169,110,0.28);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.4rem;
    color: var(--gold);
    transition: background 0.3s;
  }
  .svc-card:hover .svc-icon { background: rgba(201,169,110,0.08); }
  .svc-name {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    margin-bottom: 0.7rem;
  }
  .svc-desc { font-size: 0.76rem; color: var(--gray); line-height: 1.85; }
  .svc-price {
    margin-top: 1.1rem;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
  }
  @media (max-width: 880px) { .services-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 560px) { .services-grid { grid-template-columns: 1fr; } .section-wrap { padding: 4rem 1.5rem; } }
</style>

<section id="servicios" aria-label="Servicios de peluquería y estética Silvia Corpas">
  <div class="section-wrap">
    <p class="section-tag">Nuestros servicios</p>
    <h2 class="section-title">Todo lo que tu<br/><em>belleza</em> necesita</h2>
    <p class="section-lead">Tratamientos personalizados con los mejores productos del mercado. Porque tu imagen merece lo mejor.</p>
    <div class="services-grid">
      <article class="svc-card">
        <div class="svc-icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 2a7 7 0 017 7c0 5-7 13-7 13S5 14 5 9a7 7 0 017-7z"/><circle cx="12" cy="9" r="2.5"/></svg></div>
        <h3 class="svc-name">Corte &amp; Peinado</h3>
        <p class="svc-desc">Cortes personalizados a tu morfología y estilo de vida. Clásicos atemporales o últimas tendencias.</p>
        <p class="svc-price">Desde 35 €</p>
      </article>
      <article class="svc-card">
        <div class="svc-icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
        <h3 class="svc-name">Coloración &amp; Mechas</h3>
        <p class="svc-desc">Balayage, highlights, babylights, color global y decoloración. Colores que duran y respetan tu cabello.</p>
        <p class="svc-price">Desde 60 €</p>
      </article>
      <article class="svc-card">
        <div class="svc-icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg></div>
        <h3 class="svc-name">Tratamientos Capilares</h3>
        <p class="svc-desc">Keratina, hidratación profunda, reconstrucción capilar y rituales de nutrición para revitalizar tu cabello.</p>
        <p class="svc-price">Desde 80 €</p>
      </article>
      <article class="svc-card">
        <div class="svc-icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg></div>
        <h3 class="svc-name">Alisado Japonés</h3>
        <p class="svc-desc">Alisado permanente que transforma el cabello rizado o con frizz en una melena lisa y sedosa de larga duración.</p>
        <p class="svc-price">Desde 150 €</p>
      </article>
      <article class="svc-card">
        <div class="svc-icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg></div>
        <h3 class="svc-name">Extensiones</h3>
        <p class="svc-desc">Cabello natural 100% con métodos adaptados a cada tipo de cabello para un resultado completamente natural.</p>
        <p class="svc-price">Desde 200 €</p>
      </article>
      <article class="svc-card">
        <div class="svc-icon"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <h3 class="svc-name">Estética Avanzada</h3>
        <p class="svc-desc">Manicura, pedicura, tratamientos faciales y rituales de belleza integrales. Cuídate de pies a cabeza.</p>
        <p class="svc-price">Desde 40 €</p>
      </article>
    </div>
  </div>
</section>

<!-- ══════════ ABOUT ══════════ -->
<style>
  .about-section { background: var(--dark); padding: 6rem 3rem; }
  .about-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
  }

  /* Tarjeta visual con logo centrado */
  .about-visual { position: relative; }
  .about-card {
    aspect-ratio: 3/4;
    max-height: 520px;
    background: var(--black);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    position: relative;
    overflow: hidden;
  }
  .about-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(201,169,110,0.06) 0%, transparent 70%);
  }
  .about-logo-big {
    width: 120px; height: 120px;
    border-radius: 50%;
    border: 1px solid rgba(201,169,110,0.4);
    padding: 5px;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }
  .about-logo-big img {
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .about-monogram {
    font-family: var(--font-serif);
    font-size: 5rem;
    font-weight: 300;
    color: rgba(201,169,110,0.12);
    letter-spacing: 0.1em;
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    line-height: 1;
    z-index: 0;
    user-select: none;
  }
  .about-card-tag {
    position: relative; z-index: 1;
    font-size: 0.58rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    text-align: center;
  }
  .about-deco-badge {
    position: absolute;
    bottom: -18px; left: -18px;
    background: var(--gold);
